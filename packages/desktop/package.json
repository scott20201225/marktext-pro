{
  "name": "marktextpro",
  "version": "0.20.0-scott.24",
  "description": "MarkTextPro",
  "main": "./out/main/index.js",
  "author": {
    "name": "ScottCheng",
    "url": "https://github.com/scott20201225"
  },
  "maintainer": [
    {
      "name": "ScottCheng",
      "url": "https://github.com/scott20201225"
    }
  ],
  "homepage": "https://github.com/scott20201225/marktext-pro",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scott20201225/marktext-pro.git"
  },
  "scripts": {
    "minify-locales": "tsx ../../scripts/minify-locales.ts",
    "rebuild-native": "electron-rebuild -f",
    "start": "cross-env PERF_TESTING=true electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:unpack": "tsx ../../scripts/minify-locales.ts && electron-vite build",
    "build:win": "tsx ../../scripts/minify-locales.ts && electron-rebuild && electron-vite build && electron-builder --win --x64 --publish never",
    "build:win:x64": "tsx ../../scripts/minify-locales.ts && electron-rebuild && electron-vite build && electron-builder --win --x64 --publish never",
    "build:win:arm64": "tsx ../../scripts/minify-locales.ts && electron-rebuild && electron-vite build && electron-builder --win --arm64 --publish never",
    "build:mac": "tsx ../../scripts/minify-locales.ts && electron-rebuild && electron-vite build && electron-builder --mac --publish never",
    "build:mac:x64": "tsx ../../scripts/minify-locales.ts && electron-rebuild && electron-vite build && electron-builder --mac --x64 --publish never",
    "build:mac:arm64": "tsx ../../scripts/minify-locales.ts && electron-rebuild && electron-vite build && electron-builder --mac --arm64 --publish never",
    "build:linux": "tsx ../../scripts/minify-locales.ts && electron-rebuild && electron-vite build && electron-builder --linux --x64 --publish never",
    "build:linux:x64": "tsx ../../scripts/minify-locales.ts && electron-rebuild && electron-vite build && electron-builder --linux --x64 --publish never",
    "build:linux:arm64": "tsx ../../scripts/minify-locales.ts && electron-rebuild && electron-vite build && electron-builder --linux AppImage tar.gz --arm64 --publish never",
    "perf:inspect": "cross-env PERF_TESTING=true electron-vite preview -- --inspect=5858",
    "perf:inspect-brk": "cross-env PERF_TESTING=true electron-vite preview -- --inspect-brk=5858",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:e2e": "playwright test test/e2e",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "typecheck:watch": "vue-tsc --noEmit -p tsconfig.json --watch"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@hfelix/electron-localshortcut": "^4.0.1",
    "@intlify/core-base": "^11.4.6",
    "@marktextpro/file-icons": "workspace:*",
    "@marktextpro/muyajs": "workspace:*",
    "@muyajs/core": "workspace:*",
    "@popperjs/core": "^2.11.8",
    "@vscode/ripgrep": "^1.18.0",
    "arg": "^5.0.2",
    "axios": "^1.18.0",
    "ced": "^2.0.0",
    "chokidar": "^5.0.0",
    "codemirror": "^5.65.21",
    "command-exists": "^1.2.9",
    "dayjs": "^1.11.21",
    "deep-equal": "^2.2.3",
    "dom-autoscroller": "^2.3.4",
    "dompurify": "^3.4.11",
    "dragula": "^3.7.3",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "electron-window-state": "^5.0.3",
    "element-plus": "^2.14.2",
    "element-resize-detector": "^1.2.4",
    "execall": "^3.0.0",
    "flowchart.js": "^1.18.0",
    "font-list": "^2.1.0",
    "fs-extra": "^11.3.5",
    "fuzzaldrin": "^2.1.0",
    "github-markdown-css": "^5.9.0",
    "html-tags": "^5.1.0",
