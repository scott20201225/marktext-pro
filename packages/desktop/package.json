    "iso-639-1": "^3.1.5",
    "joplin-turndown-plugin-gfm": "^1.0.12",
    "katex": "^0.17.0",
    "keytar": "^7.9.0",
    "lodash": "^4.18.1",
    "mermaid": "^11.15.0",
    "minimatch": "^10.2.5",
    "mitt": "^3.0.1",
    "ms": "^2.1.3",
    "pako": "^2.1.0",
    "pathe": "^2.0.3",
    "pinia": "^3.0.4",
    "plist": "^5.0.0",
    "prismjs": "^1.30.0",
    "snabbdom": "^3.6.4",
    "snabbdom-to-html": "^7.1.0",
    "snapsvg-cjs": "^0.0.6",
    "turndown": "^7.2.4",
    "underscore": "^1.13.8",
    "vega-embed": "^7.1.0",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.4",
    "webfontloader": "^1.6.28",
    "write-file-atomic": "^7.0.1"
  },
  "optionalDependencies": {
    "@vscode/ripgrep-darwin-arm64": "1.18.0",
    "@vscode/ripgrep-darwin-x64": "1.18.0",
    "@vscode/ripgrep-linux-arm64": "1.18.0",
    "@vscode/ripgrep-linux-x64": "1.18.0",
    "@vscode/ripgrep-win32-arm64": "1.18.0",
    "@vscode/ripgrep-win32-x64": "1.18.0",
    "native-keymap": "^3.3.9"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.61.0",
    "@types/codemirror": "^5.60.17",
    "@types/deep-equal": "^1.0.4",
    "@types/dragula": "^3.7.5",
    "@types/element-resize-detector": "^1.1.6",
    "@types/fs-extra": "^11.0.4",
    "@types/fuzzaldrin": "^2.1.7",
    "@types/lodash": "^4.17.24",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.20.0",
    "@types/turndown": "^5.0.6",
    "@types/webfontloader": "^1.6.38",
    "@types/write-file-atomic": "^4.0.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "electron": "~42.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.1",
    "postcss-preset-env": "^11.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.1.9",
