[Desktop Entry]
Name=MarkTextPro
Comment=Next generation markdown editor
Exec=marktextpro %F
Terminal=false
Type=Application
Icon=marktextpro
Categories=Office;TextEditor;Utility;
MimeType=text/markdown;
Keywords=marktextpro;
StartupWMClass=marktextpro
Actions=NewWindow;

[Desktop Action NewWindow]
Name=New Window
Exec=marktextpro --new-window %F
Icon=marktextpro
